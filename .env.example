# Supabase – copy these from your Supabase project dashboard
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Admin – email address that gets auto-assigned the admin role on first profile save
NEXT_PUBLIC_ADMIN_EMAIL=admin@yourdomain.ac.in
